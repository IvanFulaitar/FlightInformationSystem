@model FlightSearchViewModel

@{
    ViewData["Title"] = "Flight Search";
}

<section class="mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
        <div>
            <h1 class="display-6 mb-2">Flight Information System</h1>
            <p class="text-muted mb-0">Search flights through FlightStorageService REST API.</p>
        </div>
        <form asp-action="SearchAll" method="post">
            <button type="submit" class="btn btn-outline-primary">Get all flights</button>
        </form>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Search by flight number</h2>
                <form asp-action="SearchByNumber" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="FlightNumber" class="form-label">Flight number</label>
                        <input asp-for="FlightNumber" class="form-control" placeholder="PS123" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Search by departure date</h2>
                <form asp-action="SearchByDate" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="Date" class="form-label">Date</label>
                        <input asp-for="Date" type="date" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Search by departure city and date</h2>
                <form asp-action="SearchByDeparture" method="post" class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="City" class="form-label">Departure city</label>
                        <input name="City" class="form-control" placeholder="Kyiv" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Date" class="form-label">Date</label>
                        <input name="Date" type="date" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Search by arrival city and date</h2>
                <form asp-action="SearchByArrival" method="post" class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="City" class="form-label">Arrival city</label>
                        <input name="City" class="form-control" placeholder="London" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Date" class="form-label">Date</label>
                        <input name="Date" type="date" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Search by any city</h2>
                <form asp-action="SearchByCity" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="City" class="form-label">Departure or arrival city</label>
                        <input name="City" class="form-control" placeholder="Kyiv" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </form>
            </div>
        </div>
    </div></section>
<section class="row g-3 mb-4">
    <div class="col-12">
        <h2 class="h4 mb-0">Manage flights</h2>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h5">Create flight</h3>
                <form asp-action="CreateFlight" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="CreateFlight.FlightNumber" class="form-label">Flight number</label>
                        <input asp-for="CreateFlight.FlightNumber" class="form-control" placeholder="PS123" />
                    </div>
                    <div class="col-12">
                        <label asp-for="CreateFlight.DepartureDateTime" class="form-label">Departure time</label>
                        <input asp-for="CreateFlight.DepartureDateTime" type="datetime-local" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="CreateFlight.DepartureAirportCity" class="form-label">Departure city</label>
                        <input asp-for="CreateFlight.DepartureAirportCity" class="form-control" placeholder="Kyiv" />
                    </div>
                    <div class="col-12">
                        <label asp-for="CreateFlight.ArrivalAirportCity" class="form-label">Arrival city</label>
                        <input asp-for="CreateFlight.ArrivalAirportCity" class="form-control" placeholder="London" />
                    </div>
                    <div class="col-12">
                        <label asp-for="CreateFlight.DurationMinutes" class="form-label">Duration minutes</label>
                        <input asp-for="CreateFlight.DurationMinutes" type="number" min="1" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h5">Update flight</h3>
                <form asp-action="UpdateFlight" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="UpdateFlight.FlightNumber" class="form-label">Flight number</label>
                        <input asp-for="UpdateFlight.FlightNumber" class="form-control" placeholder="PS123" />
                    </div>
                    <div class="col-12">
                        <label asp-for="UpdateFlight.DepartureDateTime" class="form-label">Departure time</label>
                        <input asp-for="UpdateFlight.DepartureDateTime" type="datetime-local" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="UpdateFlight.DepartureAirportCity" class="form-label">Departure city</label>
                        <input asp-for="UpdateFlight.DepartureAirportCity" class="form-control" placeholder="Kyiv" />
                    </div>
                    <div class="col-12">
                        <label asp-for="UpdateFlight.ArrivalAirportCity" class="form-label">Arrival city</label>
                        <input asp-for="UpdateFlight.ArrivalAirportCity" class="form-control" placeholder="London" />
                    </div>
                    <div class="col-12">
                        <label asp-for="UpdateFlight.DurationMinutes" class="form-label">Duration minutes</label>
                        <input asp-for="UpdateFlight.DurationMinutes" type="number" min="1" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-warning">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card h-100 border-danger-subtle">
            <div class="card-body">
                <h3 class="h5">Delete flight</h3>
                <form asp-action="DeleteFlight" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="DeleteFlightNumber" class="form-label">Flight number</label>
                        <input asp-for="DeleteFlightNumber" class="form-control" placeholder="PS123" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success" role="alert">
        @Model.SuccessMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

<section class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="h5 mb-1">Search results</h2>
                @if (!string.IsNullOrWhiteSpace(Model.SearchDescription))
                {
                    <p class="text-muted mb-0">@Model.SearchDescription</p>
                }
            </div>
            <span class="badge text-bg-secondary">@Model.Results.Count result(s)</span>
        </div>

        @if (Model.Results.Count == 0)
        {
            <p class="text-muted mb-0">No flights to display.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Flight number</th>
                            <th>Departure time</th>
                            <th>Departure city</th>
                            <th>Arrival city</th>
                            <th class="text-end">Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var flight in Model.Results)
                        {
                            <tr>
                                <td class="fw-semibold">@flight.FlightNumber</td>
                                <td>@flight.DepartureDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@flight.DepartureAirportCity</td>
                                <td>@flight.ArrivalAirportCity</td>
                                <td class="text-end">@flight.DurationMinutes min</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>




